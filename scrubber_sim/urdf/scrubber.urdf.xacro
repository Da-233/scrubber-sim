<?xml version="1.0"?>
<robot name="scrubber_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="length" value="1.4"/>
  <xacro:property name="width" value="1.0"/>
  <xacro:property name="height" value="1.3"/>

  <xacro:property name="mass" value="200.0"/>

  <xacro:property name="wheel_radius" value="0.15"/>
  <xacro:property name="wheel_width" value="0.1"/>
  <xacro:property name="wheel_base" value="1.0"/>
  <xacro:property name="track_width" value="0.9"/>

  <xacro:property name="brush_offset_x" value="-0.6"/>
  <xacro:property name="brush_width" value="1.0"/>

  <material name="blue">
    <color rgba="0.1 0.1 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="yellow">
    <color rgba="1 1 0 1"/>
  </material>

  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m / 12.0 * (w*w + h*h) + 0.001}" ixy="0.0" ixz="0.0"
               iyy="${m / 12.0 * (d*d + h*h) + 0.001}" iyz="0.0"
               izz="${m / 12.0 * (w*w + d*d) + 0.001}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12 + 0.001}" ixy = "0" ixz = "0"
               iyy="${m*(3*r*r+h*h)/12 + 0.001}" iyz = "0"
               izz="${m*r*r/2 + 0.001}"/>
    </inertial>
  </xacro:macro>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${length} ${width} ${height}"/>
      </geometry>
      <origin xyz="0 0 ${height/2}" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${length} ${width} ${height}"/>
      </geometry>
      <origin xyz="0 0 ${height/2}" rpy="0 0 0"/>
    </collision>
    <xacro:box_inertia m="${mass}" w="${width}" h="${height}" d="${length}"/>
  </link>

  <link name="imu_link">
    <visual>
      <geometry><box size="0.05 0.05 0.02"/></geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 ${height/2}" rpy="0 0 0"/>
  </joint>

  <link name="steering_link">
    <visual><geometry><box size="0.01 0.01 0.01"/></geometry></visual>
    <inertial><mass value="5.0"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial>
  </link>

  <joint name="steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="steering_link"/>
    <origin xyz="${wheel_base/2} 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="1000" velocity="1.0"/>
  </joint>

  <link name="front_wheel_link">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material name="black"/>
      <origin xyz="0 0 0" rpy="${-pi/2} 0 0"/>
    </visual>
    <collision>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <origin xyz="0 0 0" rpy="${-pi/2} 0 0"/>
    </collision>
    <xacro:cylinder_inertia m="10.0" r="${wheel_radius}" h="${wheel_width}"/>
  </link>

  <joint name="front_wheel_joint" type="continuous">
    <parent link="steering_link"/>
    <child link="front_wheel_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <xacro:macro name="rear_wheel" params="prefix y_offset">
    <link name="${prefix}_wheel_link">
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
        <origin xyz="0 0 0" rpy="${-pi/2} 0 0"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <origin xyz="0 0 0" rpy="${-pi/2} 0 0"/>
      </collision>
      <xacro:cylinder_inertia m="10.0" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${-wheel_base/2} ${y_offset} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:rear_wheel prefix="rear_left" y_offset="${track_width/2}"/>
  <xacro:rear_wheel prefix="rear_right" y_offset="${-track_width/2}"/>

  <link name="cleaning_tool_link">
    <visual>
        <geometry><box size="0.2 ${brush_width} 0.05"/></geometry>
        <material name="yellow"/>
    </visual>
  </link>

  <joint name="cleaning_tool_joint" type="fixed">
    <parent link="base_link"/>
    <child link="cleaning_tool_link"/>
    <origin xyz="${brush_offset_x} 0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.05" length="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="${length/2 + 0.05} 0 0.75" rpy="0 0 0"/>
  </joint>

  <!-- ================= gz-sim (Harmonic) 标签 ================= -->

  <!-- LiDAR 传感器（gz gpu_lidar） -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <topic>scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>

  <!-- IMU 传感器 -->
  <gazebo reference="imu_link">
    <sensor name="imu" type="imu">
      <topic>imu/data</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <update_rate>100</update_rate>
      <always_on>true</always_on>
    </sensor>
  </gazebo>

  <!-- 摩擦（防打滑，地图不漂） -->
  <gazebo reference="front_wheel_link">
    <mu1>0.9</mu1><mu2>0.9</mu2><kp>1e8</kp><kd>10.0</kd>
  </gazebo>
  <gazebo reference="rear_left_wheel_link">
    <mu1>1.0</mu1><mu2>1.0</mu2><kp>1e8</kp><kd>10.0</kd>
  </gazebo>
  <gazebo reference="rear_right_wheel_link">
    <mu1>1.0</mu1><mu2>1.0</mu2><kp>1e8</kp><kd>10.0</kd>
  </gazebo>

  <!-- 系统插件：阿卡曼驱动 + 关节状态 + IMU + 传感器 -->
  <gazebo>
    <plugin filename="gz-sim-ackermann-steering-system"
            name="gz::sim::systems::AckermannSteering">
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <left_steering_joint>steering_joint</left_steering_joint>
      <right_steering_joint>steering_joint</right_steering_joint>
      <kingpin_width>${track_width}</kingpin_width>
      <steering_limit>0.8</steering_limit>
      <wheel_base>${wheel_base}</wheel_base>
      <wheel_separation>${track_width}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <min_velocity>-2.0</min_velocity>
      <max_velocity>2.0</max_velocity>
      <min_acceleration>-1.0</min_acceleration>
      <max_acceleration>1.0</max_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>

    <plugin filename="gz-sim-imu-system"
            name="gz::sim::systems::Imu"/>

    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

</robot>
